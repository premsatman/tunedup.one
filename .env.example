# Calendly — Event Types → Share → copy link
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/YOUR_USERNAME/20-minute-free-call"

# Resend — https://resend.com/api-keys (verify tunedup.one domain for production)
RESEND_API_KEY=
CONTACT_FROM_EMAIL="TunedUp <hello@tunedup.one>"
CONTACT_NOTIFY_EMAIL="prem@tunedup.one"

# HubSpot — private app token + pipeline/stage for new contact form leads
# Pipeline ID example: default (board label may be "Clients")
# Stage ID example: appointmentscheduled (stage label may be "New Lead")
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PIPELINE_ID=default
HUBSPOT_STAGE_NEW_LEAD=appointmentscheduled
